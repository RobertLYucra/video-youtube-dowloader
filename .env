# Configuración de Archivos
LISTA_ENLACES=dowload-movies.txt
REGISTRO_DESCARGAS=descargas_completadas.txt

# Configuración de Descarga
CARPETA_DESTINO=descargas
# Si quieres un límite (para canales o playlists), pon un número. Déjalo vacío para sin límite.
MAX_VIDEOS_POR_ENLACE=

# Configuración de Calidad (Videos en MP4)
# Pon la resolución máxima que deseas (ejemplos: 2160 para 4K, 1440 para 2K, 1080, 720, 480). El resto se ajusta solo.
RESOLUCION_MAXIMA=1080

# Configuración Avanzada de yt-dlp
YT_DLP_EJECUTABLE=yt-dlp.exe
YT_DLP_FORMATO_SALIDA=mp4
YT_DLP_IGNORAR_ERRORES=true

# ===== MODO MP3 =====
# Cambia esto a "true" si quieres descargar SOLO AUDIO en MP3 (ignorará el video)
SOLO_AUDIO=false
